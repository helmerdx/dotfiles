# Rebind prefix key
unbind C-b
{{- if eq .chezmoi.os "darwin" }}
set-option -g prefix C-Space
bind-key C-Space send-prefix

set-option -g default-shell "/bin/zsh"
{{- else }}
{{-  if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
set-option -g prefix C-a
bind-key C-a send-prefix
{{-  else }}
set-option -g prefix C-Space
bind-key C-Space send-prefix
{{-  end }}
{{- end }}

set -g set-titles on

# Set automatic renumber of windows
set -g renumber-windows on

# Panes config
set -g base-index 1
setw -g pane-base-index 1
set -g display-panes-time 2000
set -sg repeat-time 600
set -g display-panes-colour "magenta"
set -g display-panes-active-colour "red"

# Activity monitors
setw -g monitor-activity off
set -g visual-activity off

# Custom configs
set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",*256col*:Tc"
# Undercurl support for neovim
set -as terminal-overrides ',*:Smulx=\E[4::%p1%dm'
set -as terminal-overrides ',*:Setulc=\E[58::2::%p1%{65536}%/%d::%p1%{256}%/%{255}%&%d::%p1%{255}%&%d%;m'
set -g assume-paste-time 0
set -g mouse on
set -g status on
setw -g aggressive-resize on
setw -g main-pane-width 200
set -g history-limit 50000
set -g focus-events on

# Resize pane shortcuts
bind -r H resize-pane -L 5
bind -r J resize-pane -D 5
bind -r K resize-pane -U 5
bind -r L resize-pane -R 5

# Swap panes
bind < swap-pane -U
bind > swap-pane -D

# Bindings for copy mode
bind v copy-mode
bind -T copy-mode-vi v send -X begin-selection
bind -T copy-mode-vi C-v send -X rectangle-toggle
bind -T copy-mode-vi y send -X copy-selection-and-cancel
bind -T copy-mode-vi Escape send -X cancel
bind -T copy-mode-vi H send -X start-of-line
bind -T copy-mode-vi L send -X end-of-line

# for vim shell navigations and selects in tmux panes
set-window-option -g mode-keys vi
bind-key -T copy-mode-vi 'v' send -X begin-selection
bind-key -T copy-mode-vi 'y' send -X copy-selection

# Custom bindings
bind-key | split-window -h -c "#{pane_current_path}"
bind-key - split-window -v -c "#{pane_current_path}"
bind-key r source-file ~/.tmux.conf \; display-message "Config reloaded"
bind C-l send-keys 'C-l'
bind x kill-pane

# TPM Plugins
set -g @plugin "tmux-plugins/tpm"
set -g @plugin "tmux-plugins/tmux-sensible"
set -g @plugin "tmux-plugins/tmux-resurrect"
set -g @plugin "tmux-plugins/tmux-continuum"
set -g @plugin "tmux-plugins/tmux-yank"
set -g @plugin "christoomey/vim-tmux-navigator"
set -g @plugin "tmux-plugins/tmux-online-status"
set -g @plugin "tmux-plugins/tmux-battery"
set -g @plugin "tmux-plugins/tmux-open"
set -g @plugin "sainnhe/tmux-fzf"
set -g @plugin "fcsonline/tmux-thumbs"
{{- if (eq .chezmoi.os "linux") }}
set -g @plugin "rose-pine/tmux"

set -g @rose_pine_variant "main"
{{- else }}
# This requires the latest version of bash `brew install bash`
set -g @plugin "catppuccin/tmux"

set -g @catppuccin_flavor "mocha"
set -g @catppuccin_status_background "none"
set -g @catppuccin_window_status_style "none"
set -g @catppuccin_pane_status_enabled "off"
set -g @catppuccin_pane_border_status "off"

# One Dark palette — matches starship bar, dark bg ensures readability on both light and dark terminals
od_bg="#282c34"
od_fg="#eff0f1"
od_gray="#5c6370"
od_red="#e06c75"
od_green="#98c379"
od_yellow="#e5c07b"
od_blue="#61afef"
od_purple="#c678dd"
od_teal="#56b6c2"
{{- end }}

# Extra config
# Configure Online
set -g @online_icon "ok"
set -g @offline_icon "nok"

# status left look and feel
set -g status-left-length 100
set -g status-left ""
{{- if (eq .chezmoi.os "linux") }}
set -ga status-left "#{?client_prefix,#{#[bg=#{@thm_red},fg=#{@thm_bg},bold]  #S },#{#[bg=#{@thm_bg},fg=#{@thm_green}]  #S }}"
set -ga status-left "#[bg=#{@thm_bg},fg=#{@thm_overlay_0},none]│"
set -ga status-left "#[bg=#{@thm_bg},fg=#{@thm_blue}]  #{=/-32/...:#{s|$USER|~|:#{b:pane_current_path}}} "
set -ga status-left "#[bg=#{@thm_bg},fg=#{@thm_overlay_0},none]#{?window_zoomed_flag,│,}"
set -ga status-left "#[bg=#{@thm_bg},fg=#{@thm_yellow}]#{?window_zoomed_flag,  zoom ,}"
{{- else }}
set -ga status-left "#{?client_prefix,#[bg=$od_red fg=$od_bg bold]  #S ,#[bg=$od_bg fg=$od_green]  #S }"
set -ga status-left "#[bg=$od_bg fg=$od_gray]│"
set -ga status-left "#[bg=$od_bg fg=$od_blue]  #{=/-32/...:#{s|$USER|~|:#{b:pane_current_path}}} "
set -ga status-left "#[bg=$od_bg fg=$od_gray]#{?window_zoomed_flag,│,}"
set -ga status-left "#[bg=$od_bg fg=$od_yellow]#{?window_zoomed_flag,  zoom ,}"
{{- end }}

# status right look and feel
set -g status-right-length 100
set -g status-right ""
{{- if (eq .chezmoi.os "linux") }}
set -ga status-right "#{?#{e|>=:10,#{battery_percentage}},#{#[bg=#{@thm_red},fg=#{@thm_bg}]},#{#[bg=#{@thm_bg},fg=#{@thm_pink}]}} #{battery_icon} #{battery_percentage} "
set -ga status-right "#[bg=#{@thm_bg},fg=#{@thm_overlay_0}, none]│"
set -ga status-right "#[bg=#{@thm_bg}]#{?#{==:#{online_status},ok},#[fg=#{@thm_mauve}] 󰖩 on ,#[fg=#{@thm_red},bold]#[reverse] 󰖪 off }"
{{- else }}
set -ga status-right "#{?#{e|>=:10,#{battery_percentage}},#[bg=$od_bg fg=$od_red],#[bg=$od_bg fg=$od_purple]} #{battery_icon} #{battery_percentage} "
set -ga status-right "#[bg=$od_bg fg=$od_gray]│"
set -ga status-right "#{?#{==:#{online_status},ok},#[bg=$od_bg fg=$od_teal] 󰖩 on ,#[bg=$od_bg fg=$od_red bold] 󰖪 off }"
{{- end }}

# Configure Tmux
set -g status-position bottom
{{- if (eq .chezmoi.os "linux") }}
set -g status-style "bg=#{@thm_bg}"
{{- else }}
set -g status-style "bg=$od_bg"
{{- end }}
set -g status-justify "absolute-centre"

# window look and feel
set -wg automatic-rename on
set -g automatic-rename-format "#{pane_current_command}"

set -g window-status-format " #I#{?#{!=:#{window_name},Window},: #W,} "
{{- if (eq .chezmoi.os "linux") }}
set -g window-status-style "bg=#{@thm_bg},fg=#{@thm_rosewater}"
set -g window-status-last-style "bg=#{@thm_bg},fg=#{@thm_peach}"
set -g window-status-activity-style "bg=#{@thm_red},fg=#{@thm_bg}"
set -g window-status-bell-style "bg=#{@thm_red},fg=#{@thm_bg},bold"
set -gF window-status-separator "#[bg=#{@thm_bg},fg=#{@thm_overlay_0}]│"

set -g window-status-current-format " #I#{?#{!=:#{window_name},Window},: #W,} "
set -g window-status-current-style "bg=#{@thm_peach},fg=#{@thm_bg},bold"
{{- else }}
set -g window-status-style "bg=$od_bg,fg=$od_fg"
set -g window-status-last-style "bg=$od_bg,fg=$od_yellow"
set -g window-status-activity-style "bg=$od_red,fg=$od_bg"
set -g window-status-bell-style "bg=$od_red,fg=$od_bg,bold"
set -gF window-status-separator "#[bg=$od_bg,fg=$od_gray]│"

set -g window-status-current-format " #I#{?#{!=:#{window_name},Window},: #W,} "
set -g window-status-current-style "bg=$od_yellow,fg=$od_bg,bold"
{{- end }}

# Enable Tmux Continuum
set -g @continuum-restore "on"

# TPM Binding
set -g @tpm-clean 'u'

# TPM Config
if "test ! -d ~/.tmux/plugins/tpm" \
   "run 'git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm && ~/.tmux/plugins/tpm/bin/install_plugins'"

# Initialize TMUX plugin manager (keep this line at the very bottom of tmux.conf)
run -b '~/.tmux/plugins/tpm/tpm'
