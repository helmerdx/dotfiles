# MonoLisa Code Helmer Nerd Font
# font_family      postscript_name=MonoLisaCodeHelmerNF-MediumRegular
# bold_font        postscript_name=MonoLisaCodeHelmerNF-Bold
# italic_font      postscript_name=MonoLisaCodeHelmerNF-SemiBoldItalic
# bold_italic_font postscript_name=MonoLisaCodeHelmerNF-BoldItalic

# CaskaydiaCove Nerd Font
# font_family      CaskaydiaCove Nerd Font
# bold_font        CaskaydiaCove Nerd Font Bold
# italic_font      CaskaydiaCove Nerd Font Italic
# bold_italic_font CaskaydiaCove Nerd Font Bold Italic

# CodeNewRoman Nerd Font
# font_family      CodeNewRoman Nerd Font
# bold_font        CodeNewRoman Nerd Font Bold
# italic_font      CodeNewRoman Nerd Font Italic
# bold_italic_font CodeNewRoman Nerd Font Bold Italic

# OperatorMono ssm (does not work, likely requires a restart)
# font_family OperatorMonoSSmNF-Medium
# bold_font OperatorMonoSSm Nerd Font Bold
# italic_font OperatorMonoSSm Nerd Font Italic
# bold_italic_font OperatorMonoSSm Nerd Font Bold Italic

# Other settings
# font size 20.0
macos_option_as_alt right

# Active font on this machine
font_family      postscript_name=MonoLisaCodeHelmerNF-MediumRegular
bold_font        postscript_name=MonoLisaCodeHelmerNF-Bold
italic_font      postscript_name=MonoLisaCodeHelmerNF-SemiBoldItalic
bold_italic_font postscript_name=MonoLisaCodeHelmerNF-BoldItalic
